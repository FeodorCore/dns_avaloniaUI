<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Desktop.ViewModels"
             x:Class="Desktop.Views.SalesView"
             x:DataType="vm:SalesViewModel">
    <StackPanel Spacing="20">

        <Border Background="#FFFFFF" CornerRadius="12" BorderBrush="#E9ECEF" BorderThickness="1" Padding="20">
            <StackPanel Orientation="Horizontal" Spacing="20" VerticalAlignment="Center">
                <TextBlock Text="Продажа (новый чек)" FontSize="18" FontWeight="600" Foreground="#ff9519"
                           VerticalAlignment="Center" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Classes="Label" Text="Дата:" VerticalAlignment="Center" Margin="0" />
                    <DatePicker SelectedDate="{Binding SaleDatetime, Mode=TwoWay}" Width="140" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Items list -->
        <Border Background="#FFFFFF" CornerRadius="12" BorderBrush="#E9ECEF" BorderThickness="1" Padding="20">
            <StackPanel Spacing="16">
                <Grid ColumnDefinitions="*, 80, 100, 80, 100" Margin="0,0,0,8">
                    <TextBlock Text="Товар" FontWeight="600" Foreground="#344054" />
                    <TextBlock Grid.Column="1" Text="Кол-во" FontWeight="600" Foreground="#344054"
                               TextAlignment="Center" />
                    <TextBlock Grid.Column="2" Text="Цена продажи" FontWeight="600" Foreground="#344054"
                               TextAlignment="Center" />
                    <TextBlock Grid.Column="3" Text="Себест-ть" FontWeight="600" Foreground="#344054"
                               TextAlignment="Center" />
                    <TextBlock Grid.Column="4" Text="Сумма" FontWeight="600" Foreground="#344054" TextAlignment="Right" />
                </Grid>
                <ListBox x:Name="itemsList" ItemsSource="{Binding Items}" BorderThickness="0" Background="#F8F9FA"
                         CornerRadius="8">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="vm:SaleItemViewModel">
                            <Grid ColumnDefinitions="*, 80, 100, 80, 100" Margin="0,4" VerticalAlignment="Center">
                                <ComboBox ItemsSource="{Binding $parent[UserControl].DataContext.Products}"
                                          SelectedValue="{Binding ProductId, Mode=TwoWay}"
                                          DisplayMemberBinding="{Binding Name}"
                                          SelectedValueBinding="{Binding ProductId}"
                                          PlaceholderText="Выберите товар" />
                                <TextBox Grid.Column="1" Text="{Binding Quantity, Mode=TwoWay}" TextAlignment="Center"
                                         Margin="6,0" />
                                <TextBox Grid.Column="2" Text="{Binding UnitSalePrice, Mode=TwoWay}"
                                         TextAlignment="Center" Margin="6,0" />
                                <TextBlock Grid.Column="3" Text="{Binding UnitCostPrice, StringFormat={}{0:F2}}"
                                           TextAlignment="Center" VerticalAlignment="Center" Foreground="#667085" />
                                <TextBlock Grid.Column="4" Text="{Binding Total, StringFormat={}{0:F2} ₽}"
                                           FontWeight="600" TextAlignment="Right" VerticalAlignment="Center"
                                           Foreground="#101828" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>


                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12" Margin="0,8,0,0">
                    <TextBlock Text="Итого по чеку:" FontWeight="600" Foreground="#344054" />
                    <TextBlock Text="{Binding OverallTotal, StringFormat={}{0:F2} ₽}" FontWeight="700" FontSize="20"
                               Foreground="#ff9519" />
                </StackPanel>


                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="12" Margin="0,12,0,0">
                    <Button Content="Добавить позицию" Command="{Binding AddItemCommand}" />
                    <Button Content="Удалить позицию" Command="{Binding DeleteItemCommand}"
                            CommandParameter="{Binding SelectedItem, ElementName=itemsList}" />
                    <Button Content="Сохранить продажу" Command="{Binding SaveSaleCommand}" Classes="Primary"
                            Width="180" />
                </StackPanel>


                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="#D83B01"
                           FontWeight="500"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0"
                           IsVisible="{Binding ErrorMessage, Converter={x:Static ObjectConverters.IsNotNull}}" />
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>